# =============================================================================
# SKILLLOG NAMESPACE (slog-) - TypeDB 3.x Schema
# =============================================================================
# Tracks skill invocations and LLM calls for token observability and evaluation.
#
# Entity hierarchy:
#   slog-session    -> alh-collection   (groups invocations in one Claude session)
#   slog-invocation -> alh-domain-thing (one skill command call, logged by Claude Code hook)
#   slog-input      -> alh-artifact     (raw command + args)
#   slog-output     -> alh-artifact     (raw stdout/stderr)
#   slog-llm-call   -> alh-domain-thing (one LLM API round-trip, logged by LiteLLM callback)
# =============================================================================

define

# -----------------------------------------------------------------------------
# ATTRIBUTES
# -----------------------------------------------------------------------------

attribute slog-skill-name, value string;
attribute slog-command-name, value string;
attribute slog-session-id, value string;
attribute slog-exit-code, value integer;
attribute slog-duration-ms, value integer;

# Token estimates (tiktoken cl100k_base encoding)
attribute slog-input-tokens-estimate, value integer;
attribute slog-output-tokens-estimate, value integer;
attribute slog-total-tokens-estimate, value integer;
# Estimated tokens in always-loaded static context files (CLAUDE.md, SKILL.mds, etc.)
attribute slog-context-tokens-estimate, value integer;
# Per-file breakdown of context tokens (stored since Feb 2026)
attribute slog-claude-md-tokens, value integer;
attribute slog-memory-md-tokens, value integer;
attribute slog-skill-mds-tokens, value integer;
attribute slog-soul-md-tokens, value integer;
attribute slog-agents-md-tokens, value integer;

# Evaluation label for quality tracking
# Values: unlabeled | golden | rejected
attribute slog-evaluation-label, value string;

# LLM call tracking (LiteLLM callback -> OpenClaw usage)
attribute slog-llm-model, value string;
attribute slog-cost-usd, value double;
attribute slog-cache-creation-tokens, value integer;
attribute slog-cache-read-tokens, value integer;


# -----------------------------------------------------------------------------
# ENTITY TYPES
# -----------------------------------------------------------------------------

# A Claude Code session -- groups related invocations together.
# Stored as a alh-collection for queryability across invocations.
entity slog-session sub alh-collection,
    owns slog-session-id;


# One recorded skill command execution.
entity slog-invocation sub alh-domain-thing,
    owns slog-skill-name,
    owns slog-command-name,
    owns slog-session-id,
    owns slog-exit-code,
    owns slog-duration-ms,
    owns slog-input-tokens-estimate,
    owns slog-output-tokens-estimate,
    owns slog-total-tokens-estimate,
    owns slog-context-tokens-estimate,
    owns slog-claude-md-tokens,
    owns slog-memory-md-tokens,
    owns slog-skill-mds-tokens,
    owns slog-soul-md-tokens,
    owns slog-agents-md-tokens,
    owns slog-evaluation-label;


# Raw command string + args captured as input artifact.
entity slog-input sub alh-artifact;


# Raw stdout/stderr captured as output artifact.
entity slog-output sub alh-artifact;


# One LLM API round-trip logged by the LiteLLM callback (OpenClaw production).
# Written by local_resources/skilllog/litellm_callback.py via the MCP server's
# /log-llm-call HTTP endpoint.
entity slog-llm-call sub alh-domain-thing,
    owns slog-llm-model,
    owns slog-session-id,
    owns slog-input-tokens-estimate,
    owns slog-output-tokens-estimate,
    owns slog-cache-creation-tokens,
    owns slog-cache-read-tokens,
    owns slog-cost-usd,
    owns slog-duration-ms,
    owns slog-exit-code;


# -----------------------------------------------------------------------------
# SKILL QUALITY / SCHEMA GAP TRACKING
# -----------------------------------------------------------------------------
# Records deficiencies discovered during skill use - missing data, incorrect
# inferences, unclear workflows. Enables systematic skill improvement.

attribute slog-gap-type, value string;
    # missing-user-context | missing-entity-type | missing-attribute
    # | unclear-workflow | incorrect-inference
attribute slog-gap-severity, value string;
    # minor | moderate | significant
attribute slog-gap-status, value string;
    # open | addressed | wont-fix
attribute slog-gap-example, value string;
    # the specific triggering situation (verbatim or paraphrase)
attribute slog-skill-version, value string;

# Skill model - represents a skill as a first-class trackable object.
# description (inherited) = what the skill does.
entity slog-skill-model sub alh-domain-thing,
    owns slog-skill-name,
    owns slog-skill-version,
    plays slog-skill-has-gap:skill-model;

# Schema gap - a recorded deficiency in a skill's model.
# description (inherited) = what information is missing or wrong.
entity slog-schema-gap sub alh-domain-thing,
    owns slog-gap-type,
    owns slog-gap-severity,
    owns slog-gap-status,
    owns slog-gap-example,
    plays slog-skill-has-gap:schema-gap;

relation slog-skill-has-gap,
    relates skill-model,
    relates schema-gap;
